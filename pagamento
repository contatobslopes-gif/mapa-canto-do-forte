<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Matrimap - Pagamento</title>
<style>
:root{
  --azul:#0b3d91;
  --azul-escuro:#082c68;
  --fundo:#eef3fb;
  --texto:#1f2937;
  --borda:#d9e2f1;
  --sucesso:#166534;
}
*{box-sizing:border-box}
body{
  margin:0;
  font-family:Arial,sans-serif;
  background:#eef3fb;
  min-height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:24px;
}
.wrap{
  width:100%;
  max-width:1180px;
  background:#fff;
  border-radius:24px;
  box-shadow:0 26px 50px rgba(0,0,0,.12);
  overflow:hidden;
}
.header{
  background:linear-gradient(135deg,#0b3d91,#0a3276);
  color:#fff;
  padding:34px 28px;
}
.header h1{
  margin:0 0 8px;
  font-size:34px;
}
.header p{
  margin:0;
  color:#e8f0ff;
}
.content{
  padding:34px 28px 24px;
}
.user-info{
  margin-bottom:22px;
  padding:14px 16px;
  border:1px solid #dbe6f8;
  background:#f8fbff;
  border-radius:14px;
  color:#334155;
}
.cards{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:22px;
}
.card{
  border:1px solid #dbe6f8;
  border-radius:22px;
  padding:24px 22px;
  position:relative;
  background:#fff;
}
.badge{
  position:absolute;
  top:16px;
  right:16px;
  background:#eff6ff;
  color:#0b3d91;
  border:1px solid #bfdbfe;
  border-radius:999px;
  padding:6px 10px;
  font-size:12px;
  font-weight:700;
}
.card h2{
  margin:0 0 10px;
  font-size:24px;
  color:#0f172a;
}
.price{
  font-size:38px;
  font-weight:700;
  color:#0b3d91;
  margin-bottom:10px;
}
.small{
  color:#64748b;
  margin-bottom:16px;
}
ul{
  padding-left:18px;
  color:#334155;
  line-height:1.9;
  margin-bottom:24px;
}
.btn{
  width:100%;
  border:none;
  border-radius:14px;
  padding:14px 16px;
  font-size:15px;
  font-weight:700;
  cursor:pointer;
  background:#0b3d91;
  color:#fff;
}
.btn:hover{background:#082c68}
.note{
  margin-top:18px;
  padding:14px 16px;
  border-radius:14px;
  background:#f8fafc;
  color:#475569;
  border:1px solid #e2e8f0;
}
.footer{
  margin-top:20px;
  text-align:center;
  font-size:13px;
  color:#64748b;
  line-height:1.8;
}
.top-actions{
  display:flex;
  justify-content:space-between;
  gap:14px;
  align-items:center;
  margin-bottom:18px;
}
.link-btn{
  background:none;
  border:none;
  color:#0b3d91;
  font-weight:700;
  cursor:pointer;
  padding:0;
}
@media (max-width: 900px){
  .cards{grid-template-columns:1fr}
}
</style>
</head>
<body>
  <div class="wrap">
    <div class="header">
      <h1>Escolha seu plano</h1>
      <p>Tenha acesso à plataforma Matrimap e continue sua navegação com acesso ativo.</p>
    </div>

    <div class="content">
      <div class="top-actions">
        <div class="user-info" id="userInfo">Carregando informações...</div>
        <button class="link-btn" onclick="voltarLogin()">Voltar ao login</button>
      </div>

      <div class="cards">
        <div class="card">
          <h2>Plano Mensal</h2>
          <div class="price">R$ 34,90</div>
          <div class="small">Cobrança mensal</div>
          <ul>
            <li>Acesso ao mapa enquanto o plano estiver ativo</li>
            <li>Consulta das informações disponíveis na plataforma</li>
            <li>Renovação ao final do período</li>
          </ul>
          <button class="btn" onclick="assinar('mensal')">Assinar agora</button>
        </div>

        <div class="card">
          <div class="badge">Mais vantajoso</div>
          <h2>Plano Anual</h2>
          <div class="price">R$ 349,00</div>
          <div class="small">Cobrança anual</div>
          <ul>
            <li>Acesso por 12 meses</li>
            <li>Melhor custo para uso recorrente</li>
            <li>Mesmo fluxo de acesso e renovação</li>
          </ul>
          <button class="btn" onclick="assinar('anual')">Assinar agora</button>
        </div>
      </div>

      <div class="note">
        A tela e a lógica já estão prontas para a integração com o Mercado Pago. Depois, bastará inserir os links ou a automação definitiva de cobrança.
      </div>

      <div class="footer">
        <div>Email: contatomatrimap@gmail.com</div>
        <div>WhatsApp: 19 99949-3684</div>
      </div>
    </div>
  </div>

<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/12.10.0/firebase-app.js";
import { getAuth, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/12.10.0/firebase-auth.js";
import { getDatabase, ref, get } from "https://www.gstatic.com/firebasejs/12.10.0/firebase-database.js";

const firebaseConfig = {
  apiKey: "AIzaSyC-H3jvvvtlv4g3iuP7rVgr5K-R8YSjMYo",
  authDomain: "matrimap-899b3.firebaseapp.com",
  databaseURL: "https://matrimap-899b3-default-rtdb.firebaseio.com",
  projectId: "matrimap-899b3",
  storageBucket: "matrimap-899b3.firebasestorage.app",
  messagingSenderId: "1094066148423",
  appId: "1:1094066148423:web:260b14f4e2259681554d62"
};

const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const db = getDatabase(app);

const userInfo = document.getElementById("userInfo");

// Depois, troque esses links pelos links reais do Mercado Pago
const LINK_MERCADO_PAGO_MENSAL = "";
const LINK_MERCADO_PAGO_ANUAL = "";

window.voltarLogin = function(){
  window.location.href = "index.html";
}

onAuthStateChanged(auth, async (user) => {
  if(localStorage.getItem("tipoUsuario") === "admin"){
    userInfo.textContent = "Administrador com acesso total.";
    return;
  }

  if(!user){
    userInfo.textContent = "Faça login para continuar.";
    return;
  }

  const snap = await get(ref(db, "usuarios/" + user.uid));
  if(snap.exists()){
    const dados = snap.val();
    userInfo.textContent = `Usuário: ${dados.nome || "Sem nome"} | Status: ${dados.status || "pendente_pagamento"}`;
  }else{
    userInfo.textContent = "Conta criada, aguardando ativação do plano.";
  }
});

window.assinar = function(plano){
  localStorage.setItem("planoSelecionado", plano);

  const link = plano === "mensal" ? LINK_MERCADO_PAGO_MENSAL : LINK_MERCADO_PAGO_ANUAL;

  if(link){
    window.location.href = link;
    return;
  }

  alert("Tela pronta. Quando você criar os links do Mercado Pago, basta colá-los no código desta página.");
}
</script>
</body>
</html>
